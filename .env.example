ENV=development

#SERVER
PORT=3000
SERVER_URL=http://localhost:3000

#Frontend (used in confirmation email links)
FRONTEND_URL=http://localhost:3001

#Database local
DATABASE_URL="mongodb://localhost:27017/base"

#Migration
MIGRATE_MONGO_URI="mongodb://localhost:27017/base"
MIGRATE_AUTOSYNC="true"

#BCRYPT
SALT_ROUNDS="10"

#EMAIL_SERVICE (get your key from https://resend.com)
EMAIL_SERVICE_API_KEY=""

#JWT tokens — use a random string of at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=""
REFRESH_TOKEN_SECRET=""

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3001

# OCR microservice (start with: cd trocr && python trocr_service.py)
TROCR_URL=http://localhost:5001

# Gemini vision for handwriting OCR (free tier — get key at aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash