{
  "info": {
    "name": "base_server",
    "_postman_id": "b8a0c0a2-0000-0000-0000-000000000001",
    "description": "Collection for base_server (Express + Mongo + OCR). Import into Postman or Thunder Client. Run 'Register' first, then read the OTP from MongoDB (collection: users, field: accountConfirmation.token and .code) and use them in 'Confirm Registration'. Then run Login — the accessToken cookie is set automatically and used by all authenticated requests (/me, /logout, /ocr/extract).\n\nphoneNumber accepts both '+14155552671' and '14155552671' formats.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/v1" },
    { "key": "email", "value": "test_user@example.com" },
    { "key": "password", "value": "Test@1234" },
    { "key": "phoneNumber", "value": "14155552671" },
    { "key": "confirmationToken", "value": "<paste from MongoDB users.accountConfirmation.token>" },
    { "key": "confirmationCode", "value": "<paste from MongoDB users.accountConfirmation.code>" }
  ],
  "item": [
    {
      "name": "GET /self (liveness)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/self", "host": ["{{baseUrl}}"], "path": ["self"] }
      }
    },
    {
      "name": "GET /health (app + system stats)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "POST /register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"password\": \"{{password}}\",\n  \"consent\": true\n}"
        },
        "url": { "raw": "{{baseUrl}}/register", "host": ["{{baseUrl}}"], "path": ["register"] }
      }
    },
    {
      "name": "PATCH /registeration/confirm/:token?code=:code",
      "request": {
        "method": "PATCH",
        "url": {
          "raw": "{{baseUrl}}/registeration/confirm/{{confirmationToken}}?code={{confirmationCode}}",
          "host": ["{{baseUrl}}"],
          "path": ["registeration", "confirm", "{{confirmationToken}}"],
          "query": [{ "key": "code", "value": "{{confirmationCode}}" }]
        }
      }
    },
    {
      "name": "POST /login (sets accessToken + refreshToken cookies)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
      }
    },
    {
      "name": "GET /user/me (cookie-auth)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/user/me", "host": ["{{baseUrl}}"], "path": ["user", "me"] }
      }
    },
    {
      "name": "PUT /logout (cookie-auth)",
      "request": {
        "method": "PUT",
        "url": { "raw": "{{baseUrl}}/logout", "host": ["{{baseUrl}}"], "path": ["logout"] }
      }
    },
    {
      "name": "Negative — POST /login wrong password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"Wrong@1234\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
      }
    },
    {
      "name": "Negative — POST /register invalid payload",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"X\",\n  \"email\": \"not-email\",\n  \"phoneNumber\": \"x\",\n  \"password\": \"short\",\n  \"consent\": false\n}"
        },
        "url": { "raw": "{{baseUrl}}/register", "host": ["{{baseUrl}}"], "path": ["register"] }
      }
    },
    {
      "name": "Negative — GET /user/me no auth",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/user/me", "host": ["{{baseUrl}}"], "path": ["user", "me"] }
      }
    },
    {
      "name": "POST /ocr/extract (cookie-auth, form-data)",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "image",
              "type": "file",
              "src": "",
              "description": "Select a JPEG, PNG, WebP, or TIFF image file (max 10 MB)"
            }
          ]
        },
        "url": { "raw": "{{baseUrl}}/ocr/extract", "host": ["{{baseUrl}}"], "path": ["ocr", "extract"] },
        "description": "Requires a valid accessToken cookie from POST /login. Upload an image file under the 'image' form field. Returns { text, confidence, processingTimeMs }."
      }
    },
    {
      "name": "Negative — POST /ocr/extract no auth",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": "" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/ocr/extract", "host": ["{{baseUrl}}"], "path": ["ocr", "extract"] }
      }
    },
    {
      "name": "Negative — POST /ocr/extract wrong file type",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "image",
              "type": "file",
              "src": "",
              "description": "Upload a .pdf or other non-image file to test 422 rejection"
            }
          ]
        },
        "url": { "raw": "{{baseUrl}}/ocr/extract", "host": ["{{baseUrl}}"], "path": ["ocr", "extract"] }
      }
    }
  ]
}
